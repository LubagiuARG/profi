# ── ElectroAR Backend — Variables de entorno ──────────────────────────────────
# Copiá este archivo como .env y completá los valores
# NUNCA subas .env a GitHub

# Puerto del servidor
PORT=3001

# API Key de Anthropic (solo en el backend, nunca en el frontend)
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXX

# Origen permitido del frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# URL del sitio a scrapear
SCRAPER_URL=https://www.electroinstalador.com/paginas/p43-cmo-listado-de-costos-de-mano-de-obra

# En producción: Agregar aquí credenciales de PostgreSQL si usás DB real
# DATABASE_URL=postgresql://user:password@localhost:5432/electroar
